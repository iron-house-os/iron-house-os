POSTGRES_DB=iron_house_os
POSTGRES_USER=iron_house
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
SECRET_KEY=replace-with-at-least-32-random-characters
BOOTSTRAP_ADMIN_EMAIL=jeremie@ironhousecivil.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-random-login-password
BOOTSTRAP_ADMIN_NAME=Jeremie Peters
SESSION_COOKIE_SECURE=true
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
IHOS_STORAGE_BACKEND=local
IHOS_STORAGE_ROOT=/app/data/uploads
# S3-compatible storage (set IHOS_STORAGE_BACKEND=s3 and replace values below).
IHOS_STORAGE_S3_BUCKET=
IHOS_STORAGE_S3_PREFIX=iron-house-os
IHOS_STORAGE_S3_ENDPOINT_URL=
IHOS_STORAGE_CACHE_ROOT=/app/data/object-cache
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
IHOS_PORT=8080
