APP_NAME=Iron House OS API
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://iron_house:iron_house_dev@localhost:5432/iron_house_os
SECRET_KEY=change-me-in-development
ACCESS_TOKEN_EXPIRE_MINUTES=480
SESSION_COOKIE_NAME=ihos_session
SESSION_COOKIE_SECURE=false
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
IHOS_STORAGE_BACKEND=local
IHOS_STORAGE_ROOT=/app/data/uploads
IHOS_STORAGE_S3_BUCKET=
IHOS_STORAGE_S3_PREFIX=iron-house-os
IHOS_STORAGE_S3_ENDPOINT_URL=
IHOS_STORAGE_CACHE_ROOT=/app/data/object-cache
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Set these before running python -m app.db.bootstrap_admin.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Iron House Administrator
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
# Separate Iron House Chat provider credential. Keep server-side only.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-sol
IRON_HOUSE_CHAT_ENABLED=true
